{
  "name": "br-pos-app",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "dist:win": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "electron-log": "^5.0.0",
    "electron-updater": "^6.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.br.pos",
    "productName": "BR Pos",
    "directories": { "output": "release" },
    "files": ["dist-electron/**", "dist-renderer/**"],
    "win": { "target": ["portable"] },
    "publish": [{ "provider": "github" }]
  }
}