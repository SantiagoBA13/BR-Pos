{
  "name": "br-pos-app",
  "version": "0.1.0",
  "private": true,
  "description": "BR Pos - Windows portable POS with GitHub updates",
  "author": "BR Pos",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "typecheck:electron": "tsc -p tsconfig.electron.json --noEmit",
    "dist:win": "npm run build && electron-builder --win portable",
    "dist:win:publish": "npm run build && electron-builder --win portable --publish always"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "electron-log": "^5.0.0",
    "electron-updater": "^6.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.33",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.21"
  },
  "build": {
    "appId": "com.br.pos",
    "productName": "BR Pos",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**",
      "dist-renderer/**"
    ],
    "win": {
      "target": [
        "portable"
      ]
    },
    "publish": [
      {
        "provider": "github"
      }
    ]
  }
}